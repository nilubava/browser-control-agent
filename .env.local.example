# Copy this file to .env.local and fill in your values
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: set to "true" to run browser in headless mode (default: false so you can watch it work)
BROWSER_HEADLESS=false

# Optional: max steps before giving up (default: 40)
AGENT_MAX_STEPS=40

# Optional: override which Claude model runs each role (all default to claude-sonnet-4-6)
# AGENT_MODEL=claude-sonnet-4-6       # the main loop — fires every step
# PLANNER_MODEL=claude-sonnet-4-6     # one upfront call to resolve the goal
# VERIFIER_MODEL=claude-sonnet-4-6    # pre-done() check against hallucinated success
# Use claude-opus-4-8 for AGENT_MODEL if Sonnet struggles on a complex task
